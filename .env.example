# LLM provider: azure | groq | gemini | ollama
HELIOAI_LLM_PROVIDER=azure

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=                   # https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=models-gpt-53-chat  # nom du deployment dans le portail Azure
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Agent config
HELIOAI_MAX_ITERATIONS=10
HELIOAI_LOG_FORMAT=console  # console | json

# Session DB
HELIOAI_SESSION_DB=data/sessions.db

# User profile (markdown injected into system prompt)
# HELIOAI_PROFILE=data/profile.md

# Derived recipes directory
# HELIOAI_RECIPES_DIR=data/recipes

# Dev token — unlocks unrestricted LLM access (bypasses helio-only scope guardrail).
# Leave empty (or unset) to keep the instance fully restricted (production default).
# HELIOAI_DEV_TOKEN=

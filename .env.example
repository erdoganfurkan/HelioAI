# LLM provider: groq | gemini | ollama
HELIOAI_LLM_PROVIDER=groq

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Agent config
HELIOAI_MAX_ITERATIONS=10
HELIOAI_LOG_FORMAT=console  # console | json

# Session DB
HELIOAI_SESSION_DB=data/sessions.db
